#!/usr/bin/env python3
"""Tiny stdlib-only HTTP server for the parallel-compare viewer.

Two routes:
  GET  /<file>     — serve compare.html, state.json, or any sibling file
  POST /decision   — accept the user's final pick (and any edited code),
                     write it to decision.json. The chat-side watcher
                     polls decision.json and resumes once it appears.

PID is written to server.pid on startup so the chat can `kill` it cleanly
during cleanup.

Why a custom server instead of `python -m http.server`?
  python -m http.server is GET-only — it can't accept the user's submitted
  decision. We need ~30 lines of POST handling, so a custom subclass of
  BaseHTTPRequestHandler is the smallest thing that works.
"""

import json
import os
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path

SESSION_DIR = Path(__file__).parent.resolve()


class Handler(BaseHTTPRequestHandler):
    def _send(self, status: int, body: bytes, content_type: str = "text/plain") -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self) -> None:
        rel = self.path.lstrip("/").split("?", 1)[0] or "compare.html"
        target = (SESSION_DIR / rel).resolve()
        # Path-traversal guard: reject anything outside SESSION_DIR.
        try:
            target.relative_to(SESSION_DIR)
        except ValueError:
            self._send(403, b"forbidden")
            return
        if not target.is_file():
            self._send(404, b"not found")
            return
        ct = {
            ".html": "text/html; charset=utf-8",
            ".json": "application/json; charset=utf-8",
            ".js": "text/javascript; charset=utf-8",
            ".css": "text/css; charset=utf-8",
        }.get(target.suffix, "application/octet-stream")
        self._send(200, target.read_bytes(), ct)

    def do_POST(self) -> None:
        if self.path != "/decision":
            self._send(404, b"not found")
            return
        length = int(self.headers.get("Content-Length", "0"))
        try:
            data = json.loads(self.rfile.read(length))
        except json.JSONDecodeError:
            self._send(400, b'{"error":"invalid json"}', "application/json")
            return
        (SESSION_DIR / "decision.json").write_text(json.dumps(data, indent=2))
        self._send(200, b'{"status":"ok"}', "application/json")

    def log_message(self, fmt: str, *args) -> None:
        # Quieter logs — every poll would otherwise spam stderr at 0.7 Hz.
        msg = fmt % args
        if " 200 " not in msg and " 304 " not in msg:
            sys.stderr.write(f"{self.address_string()} - {msg}\n")


def main() -> None:
    port = int(os.environ.get("VIEWER_PORT", "8765"))
    server = HTTPServer(("127.0.0.1", port), Handler)
    (SESSION_DIR / "server.pid").write_text(str(os.getpid()))
    sys.stderr.write(f"viewer up at http://localhost:{port}/\n")
    sys.stderr.flush()
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
